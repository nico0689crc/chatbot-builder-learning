generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Fase 4 — Schema inicial
// Se irá expandiendo en sesiones 11 y 12
// ---------------------------------------------------------------------------

model Cliente {
  id           String   @id @default(cuid())
  nombre       String
  arquetipo    String   // "faq" | "soporte" | "turnos" | "ventas"
  systemPrompt String
  activo       Boolean  @default(true)
  creadoEn     DateTime @default(now())

  conversaciones Conversacion[]
}

model Conversacion {
  id         String    @id @default(cuid())
  clienteId  String
  sessionId  String
  creadaEn   DateTime  @default(now())
  cerradaEn  DateTime?

  cliente  Cliente   @relation(fields: [clienteId], references: [id])
  mensajes Mensaje[]

  @@unique([clienteId, sessionId])
}

model Mensaje {
  id             String   @id @default(cuid())
  conversacionId String
  rol            String   // "user" | "assistant"
  contenido      String
  creadoEn       DateTime @default(now())

  conversacion Conversacion @relation(fields: [conversacionId], references: [id])
}
