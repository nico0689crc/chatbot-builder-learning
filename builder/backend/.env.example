# Base de datos (PostgreSQL)
DATABASE_URL=postgresql://user:password@host:port/dbname

# LLM
GOOGLE_API_KEY=your-google-api-key
DEFAULT_LLM_PROVIDER=google        # google | openai | anthropic
DEFAULT_LLM_MODEL=gemini-2.5-flash

# Meta / WhatsApp webhook
# Definí este valor vos — Meta lo usa para verificar que el webhook es tuyo
META_VERIFY_TOKEN=your-secret-verify-token
# Clave para encriptar el metaAccessToken en la BD (mínimo 32 caracteres) openssl rand -hex 32
META_ENCRYPTION_KEY=your-secret-encryption-key-min-32-chars
